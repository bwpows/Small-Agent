# === LLM 推理 API Key ===
# DeepSeek: 在 platform.deepseek.com 注册后创建 API Key
DEEPSEEK_API_KEY=

# 通用云端（OpenAI / Kimi 等）
LLM_API_KEY=

# === 嵌入 API Key ===
# 硅基流动（推荐，永久免费 BGE 中文向量模型，国内直连）
# 前往 https://siliconflow.cn 注册获取
SILICONFLOW_API_KEY=

# OpenAI 嵌入备用
OPENAI_API_KEY=

# === 飞书机器人 ===
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFY_TOKEN=
FEISHU_ENCRYPT_KEY=

# 服务公网地址
SERVER_BASE_URL=https://agent.bwpow.com

# 前端地址
FRONTEND_URL=https://agent.bwpow.com

# === Google Service Account（Drive 公共访问） ===
# 方式 A：直接把 JSON 文件内容粘贴到下方
GOOGLE_SERVICE_ACCOUNT_JSON=
# 方式 B：指定 Service Account JSON 文件路径
GOOGLE_SERVICE_ACCOUNT_FILE=

# === Google OAuth 登录（需在 Google Cloud Console 创建 Web application 类型的 OAuth Client） ===
GOOGLE_LOGIN_CLIENT_ID=
GOOGLE_LOGIN_CLIENT_SECRET=

# === JWT / 安全 ===
JWT_SECRET=change-me-in-production-please
TOKEN_ENCRYPTION_KEY=change-me-to-a-random-32-byte-string!!

# === 邮箱通知（可选） ===
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
SENDER_EMAIL=
SMTP_AUTH_CODE=
